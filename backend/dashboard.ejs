<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet"/>
<style>
:root { --primary: #0B1F3A; --accent: #FFC107; --bg-light: #F8FAFC; }
body { font-family: 'Inter', sans-serif; background-color: var(--bg-light); }
.sidebar-item-active { background-color: rgba(255,255,255,0.1); border-left: 4px solid var(--accent); }
</style>
<script>
tailwind.config = { theme: { extend: { colors: { primary: '#0B1F3A', accent: '#FFC107' } } } }
</script>
</head>
<body class="antialiased text-slate-800">
<div class="flex min-h-screen">

  <%- include('../partials/sidebar') %>

  <main class="flex-1 ml-64 flex flex-col">
    <%- include('../partials/header') %>

    <div class="p-8 space-y-8">

     

      <!-- Stats Cards -->
      <div class="grid grid-cols-4 gap-6">

        <div class="bg-white p-6 rounded-xl shadow border">
          <p class="text-xs text-slate-500 uppercase font-bold">Total Revenue</p>
          <h3 class="text-2xl font-bold text-primary mt-2">
            LKR <%= Number(stats.revenue).toLocaleString() %>
          </h3>
          <p class="text-xs text-slate-400 mt-1">From completed orders</p>
        </div>

        <a href="/admin/orders" class="bg-white p-6 rounded-xl shadow border hover:shadow-md transition">
          <p class="text-xs text-slate-500 uppercase font-bold">Total Orders</p>
          <h3 class="text-2xl font-bold text-primary mt-2"><%= stats.orders %></h3>
          <p class="text-xs text-slate-400 mt-1">All time orders</p>
        </a>

        <a href="/admin/customers" class="bg-white p-6 rounded-xl shadow border hover:shadow-md transition">
          <p class="text-xs text-slate-500 uppercase font-bold">Customers</p>
          <h3 class="text-2xl font-bold text-primary mt-2"><%= stats.customers %></h3>
          <p class="text-xs text-slate-400 mt-1">Registered customers</p>
        </a>

        <a href="/admin/products" class="bg-white p-6 rounded-xl shadow border hover:shadow-md transition">
          <p class="text-xs text-slate-500 uppercase font-bold">Active Products</p>
          <h3 class="text-2xl font-bold text-primary mt-2"><%= stats.products %></h3>
          <p class="text-xs text-slate-400 mt-1">In inventory</p>
        </a>

      </div>

      <!-- Order Status Summary -->
      <div class="grid grid-cols-3 gap-6">

        <div class="bg-white p-6 rounded-xl shadow border">
          <div class="flex items-center justify-between">
            <p class="text-xs text-slate-500 uppercase font-bold">Pending Orders</p>
            <span class="text-yellow-500 text-sm font-bold"><%= stats.pendingOrders %></span>
          </div>
          <div class="mt-3 h-2 bg-slate-100 rounded-full">
            <div class="h-2 bg-yellow-400 rounded-full" style="width: <%= stats.orders > 0 ? Math.round((stats.pendingOrders / stats.orders) * 100) : 0 %>%"></div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow border">
          <div class="flex items-center justify-between">
            <p class="text-xs text-slate-500 uppercase font-bold">Completed Orders</p>
            <span class="text-green-600 text-sm font-bold"><%= stats.completedOrders %></span>
          </div>
          <div class="mt-3 h-2 bg-slate-100 rounded-full">
            <div class="h-2 bg-green-500 rounded-full" style="width: <%= stats.orders > 0 ? Math.round((stats.completedOrders / stats.orders) * 100) : 0 %>%"></div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow border">
          <div class="flex items-center justify-between">
            <p class="text-xs text-slate-500 uppercase font-bold">Cancelled Orders</p>
            <span class="text-red-500 text-sm font-bold"><%= stats.cancelledOrders %></span>
          </div>
          <div class="mt-3 h-2 bg-slate-100 rounded-full">
            <div class="h-2 bg-red-400 rounded-full" style="width: <%= stats.orders > 0 ? Math.round((stats.cancelledOrders / stats.orders) * 100) : 0 %>%"></div>
          </div>
        </div>

      </div>

      <!-- Recent Orders -->
      <div class="bg-white rounded-xl shadow border p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-bold text-primary">Recent Orders</h3>
          <a href="/admin/orders" class="text-sm text-blue-600 hover:underline">View All</a>
        </div>
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">No</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Customer</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Date</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Total</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% recentOrders.forEach((o, i) => { %>
            <%
              const d = new Date(o.created_at);
              const dateStr = d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })
                            + ' ' + d.toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit', hour12:true });
            %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3 text-sm text-slate-500"><%= i + 1 %></td>
              <td class="px-4 py-3 text-sm font-medium"><%= o.customerName || '—' %></td>
              <td class="px-4 py-3 text-sm text-slate-500"><%= dateStr %></td>
              <td class="px-4 py-3 text-sm font-semibold">LKR <%= Number(o.total).toLocaleString() %></td>
              <td class="px-4 py-3 text-sm">
                <% if(o.status === 'completed'){ %>
                  <span class="text-green-600 font-semibold">Completed</span>
                <% } else if(o.status === 'pending'){ %>
                  <span class="text-yellow-600 font-semibold">Pending</span>
                <% } else { %>
                  <span class="text-red-600 font-semibold">Cancelled</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% if(recentOrders.length === 0){ %>
            <tr><td colspan="5" class="px-4 py-6 text-center text-slate-400">No orders yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

    <%- include('../partials/footer') %>
  </main>
</div>
</body>
</html>
