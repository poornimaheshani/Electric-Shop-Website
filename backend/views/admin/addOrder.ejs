<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Add Order - NetTec Admin</title>
<script src="https://cdn.tailwindcss.com?plugins=forms"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet"/>
<style>
  :root {
    --primary: #0B1F3A;
    --accent: #FFC107;
    --bg-light: #F8FAFC;
    --ring: rgba(255, 193, 7, 0.45);
  }
  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg-light);
  }
  .sidebar-item-active {
    background-color: rgba(255, 255, 255, 0.1);
    border-left: 4px solid var(--accent);
  }
  .page-glow {
    background:
      radial-gradient(500px circle at 20% 8%, rgba(255, 193, 7, 0.15), transparent 60%),
      radial-gradient(450px circle at 90% 12%, rgba(11, 31, 58, 0.12), transparent 60%);
  }
  .input-base {
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 10px 14px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .input-base:focus {
    border-color: #eab308;
    box-shadow: 0 0 0 3px var(--ring);
    outline: none;
  }
</style>

<script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        primary: '#0B1F3A',
        accent: '#FFC107'
      }
    }
  }
}
</script>
</head>

<body class="antialiased text-slate-800">
<div class="flex min-h-screen">

  <%- include('../partials/sidebar') %>

  <main class="flex-1 ml-64 flex flex-col page-glow">
    <%- include('../partials/header') %>

    <section class="p-8 space-y-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/admin/orders" class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-slate-200 text-slate-600 hover:text-primary hover:border-slate-300">
            <span class="material-symbols-outlined">arrow_back</span>
          </a>
          <div>
            <p class="text-xs uppercase tracking-wider font-semibold text-slate-500">Order Workflow</p>
            <h1 class="text-3xl font-extrabold text-primary">Add New Order</h1>
          </div>
        </div>
        <a href="/admin/orders" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 font-semibold">
          <span class="material-symbols-outlined text-base">list</span>
          View Orders
        </a>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <div class="xl:col-span-2 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 py-5 border-b bg-slate-50">
            <h2 class="text-lg font-bold text-primary">Order Details</h2>
            <p class="text-sm text-slate-500 mt-1">Create a new order and assign it to a customer.</p>
          </div>

          <form method="POST" action="/admin/orders/add" class="p-6 space-y-5">
            <div>
              <label for="customer_id" class="block text-sm font-semibold text-slate-700 mb-2">Customer</label>
              <select id="customer_id" name="customer_id" required class="w-full input-base bg-white">
                <option value="">-- Select Customer --</option>
                <% customers.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.name %><% if (c.email) { %> (<%= c.email %>)<% } %></option>
                <% }) %>
              </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="total" class="block text-sm font-semibold text-slate-700 mb-2">Total (LKR)</label>
                <input id="total" type="number" name="total" min="0" step="0.01" required placeholder="e.g. 25000.00" class="w-full input-base"/>
              </div>

              <div>
                <label for="status" class="block text-sm font-semibold text-slate-700 mb-2">Status</label>
                <select id="status" name="status" class="w-full input-base bg-white">
                  <option value="pending">Pending</option>
                  <option value="completed">Completed</option>
                  <option value="cancelled">Cancelled</option>
                </select>
              </div>
            </div>

            <div class="pt-3 flex flex-wrap gap-3">
              <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-accent text-primary font-bold hover:bg-yellow-300 transition-colors">
                <span class="material-symbols-outlined text-base">save</span>
                Save Order
              </button>
              <a href="/admin/orders" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-slate-100 text-slate-700 font-semibold hover:bg-slate-200 transition-colors">
                <span class="material-symbols-outlined text-base">close</span>
                Cancel
              </a>
            </div>
          </form>
        </div>

        <aside class="space-y-4">
          <div class="bg-primary text-white rounded-2xl p-6 shadow-sm">
            <p class="text-xs uppercase tracking-wider text-slate-300">Quick Info</p>
            <h3 class="text-xl font-bold mt-1">Ready to Place</h3>
            <p class="text-sm text-slate-300 mt-2">Select a customer, enter amount, then choose the order status.</p>
            <div class="mt-5 grid grid-cols-2 gap-3">
              <div class="rounded-xl bg-white/10 p-3">
                <p class="text-xs text-slate-300">Customers</p>
                <p class="text-2xl font-extrabold"><%= customers.length %></p>
              </div>
              <div class="rounded-xl bg-white/10 p-3">
                <p class="text-xs text-slate-300">Default</p>
                <p class="text-base font-bold">Pending</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
            <h4 class="font-bold text-primary">Tips</h4>
            <ul class="mt-3 text-sm text-slate-600 space-y-2">
              <li>Use the exact paid amount as the order total.</li>
              <li>Set <b>Completed</b> only after payment confirmation.</li>
              <li>You can edit status later from the orders list.</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>
  </main>
</div>
</body>
</html>
