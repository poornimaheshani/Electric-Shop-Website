<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NetTec Admin Login</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#0b203c",
            accent: "#FFC107",
            "background-dark": "#050d1a"
          },
          fontFamily: { display: ["Inter", "sans-serif"] },
          borderRadius: { DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", "2xl": "1rem", full: "9999px" }
        }
      }
    }
  </script>
  <style>
    body { font-family: "Inter", sans-serif; background-color: #0b203c; }
    .glass-card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 bg-primary">

  <div class="w-full max-w-md">
    <!-- Header -->
    <div class="flex flex-col items-center mb-8">
      <div class="bg-accent text-primary p-3 rounded-2xl shadow-lg mb-4">
        <span class="material-symbols-outlined text-4xl font-bold">bolt</span>
      </div>
      <h1 class="text-3xl font-bold text-white tracking-tight">NetTec</h1>
      <p class="text-blue-200/70 text-sm mt-1 uppercase tracking-[0.2em] font-medium">Sri Lanka eCommerce</p>
    </div>

    <!-- Login Card -->
    <div class="glass-card rounded-3xl shadow-2xl overflow-hidden border border-white/20">
      <div class="p-8">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-primary">Admin Portal</h2>
          <p class="text-slate-500 text-sm mt-1">Please sign in to your dashboard</p>
        </div>

        <!-- Login Form -->
        <form action="/admin/login" method="POST" class="space-y-6">
          <!-- Role -->
          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-400 uppercase tracking-wider ml-1">Account Type</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="cursor-pointer">
                <input checked class="peer hidden" name="role" type="radio" value="master" />
                <div class="flex items-center justify-center p-3 rounded-xl border-2 border-slate-100 bg-slate-50 text-slate-500 peer-checked:border-accent peer-checked:bg-accent/5 peer-checked:text-primary transition-all duration-200">
                  <span class="material-symbols-outlined mr-2 text-xl">admin_panel_settings</span>
                  <span class="text-sm font-semibold">Master</span>
                </div>
              </label>
              <label class="cursor-pointer">
                <input class="peer hidden" name="role" type="radio" value="staff" />
                <div class="flex items-center justify-center p-3 rounded-xl border-2 border-slate-100 bg-slate-50 text-slate-500 peer-checked:border-accent peer-checked:bg-accent/5 peer-checked:text-primary transition-all duration-200">
                  <span class="material-symbols-outlined mr-2 text-xl">person</span>
                  <span class="text-sm font-semibold">Staff</span>
                </div>
              </label>
            </div>
          </div>

          <!-- Email -->
          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-400 uppercase tracking-wider ml-1">Email Address</label>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
              <input name="email" type="email" required placeholder="admin@nettec.lk" class="w-full pl-12 pr-4 py-3.5 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-accent text-slate-800 placeholder:text-slate-400 transition-all"/>
            </div>
          </div>

          <!-- Password -->
          <div class="space-y-2">
            <div class="flex justify-between items-center ml-1">
              <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">Password</label>
              <a href="#" class="text-xs font-semibold text-primary/60 hover:text-primary">Forgot?</a>
            </div>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
              <input name="password" type="password" required placeholder="••••••••" class="w-full pl-12 pr-12 py-3.5 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-accent text-slate-800 placeholder:text-slate-400 transition-all"/>
              <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary">
                <span class="material-symbols-outlined text-xl">visibility</span>
              </button>
            </div>
          </div>

          <!-- Remember -->
          <div class="flex items-center gap-2 px-1">
            <input id="remember" type="checkbox" class="w-4 h-4 rounded border-slate-300 text-primary focus:ring-accent"/>
            <label for="remember" class="text-sm text-slate-600 font-medium">Keep me signed in</label>
          </div>

          <!-- Submit -->
          <button type="submit" class="w-full bg-primary hover:bg-slate-800 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-2">
            Sign In to Dashboard
            <span class="material-symbols-outlined transition-transform">arrow_forward</span>
          </button>
        </form>
      </div>

      <div class="bg-slate-50 border-t border-slate-100 p-6 text-center">
        <p class="text-xs text-slate-400 flex items-center justify-center gap-1">
          <span class="material-symbols-outlined text-xs">verified_user</span>
          Secure Terminal • NetTec SL Support: +94 11 234 5678
        </p>
      </div>
    </div>

    <div class="text-center mt-8">
      <p class="text-blue-200/40 text-xs font-medium uppercase tracking-widest">
        © 2026 NetTec Electronic • Colombo
      </p>
    </div>
  </div>

</body>
</html>