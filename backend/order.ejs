<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Orders - NetTec Admin</title>

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet"/>

<style>
:root {
    --primary: #0B1F3A;
    --accent: #FFC107;
    --bg-light: #F8FAFC;
}
body {
    font-family: 'Inter', sans-serif;
    background-color: var(--bg-light);
}
.sidebar-item-active {
    background-color: rgba(255, 255, 255, 0.1);
    border-left: 4px solid var(--accent);
}
.status-completed { color: #16a34a; font-weight: 600; }
.status-pending { color: #ca8a04; font-weight: 600; }
.status-cancelled { color: #dc2626; font-weight: 600; }
</style>

<script>
tailwind.config = {
    theme: {
        extend: {
            colors: {
                primary: '#0B1F3A',
                accent: '#FFC107',
            },
        },
    },
}
</script>
</head>

<body class="antialiased text-slate-800">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <!-- Main -->
    <main class="flex-1 ml-64 flex flex-col">

        <!-- Header -->
        <%- include('../partials/header') %>

        <!-- Content -->
        <div class="p-8 space-y-8">

            

            <!-- Summary Cards -->
            <div class="grid grid-cols-4 gap-6">
                <div class="bg-white p-6 rounded-xl shadow border">
                    <p class="text-xs text-slate-500 uppercase font-bold">Total Orders</p>
                    <h3 class="text-2xl font-bold text-primary mt-2"><%= totalOrders %></h3>
                </div>
                <div class="bg-white p-6 rounded-xl shadow border">
                    <p class="text-xs text-slate-500 uppercase font-bold">Pending Orders</p>
                    <h3 class="text-2xl font-bold text-primary mt-2"><%= pendingOrders %></h3>
                </div>
                <div class="bg-white p-6 rounded-xl shadow border">
                    <p class="text-xs text-slate-500 uppercase font-bold">Completed Orders</p>
                    <h3 class="text-2xl font-bold text-primary mt-2"><%= completedOrders %></h3>
                </div>
                <div class="bg-white p-6 rounded-xl shadow border">
                    <p class="text-xs text-slate-500 uppercase font-bold">Cancelled Orders</p>
                    <h3 class="text-2xl font-bold text-primary mt-2"><%= cancelledOrders %></h3>
                </div>
            </div>

            <!-- Filters -->
            <% const viewFilters = typeof filters !== 'undefined' ? filters : {}; %>
            <form class="flex gap-4 items-center bg-white p-4 rounded-xl shadow border" method="GET" action="/admin/orders">
                <input type="text" name="search" placeholder="Search by order ID, customer..."
                       value="<%= viewFilters.search || '' %>"
                       class="border rounded p-2 flex-1"/>
                <select name="status" class="border rounded p-2">
                    <option value="">All Status</option>
                    <option value="pending"   <%= viewFilters.status === 'pending'   ? 'selected' : '' %>>Pending</option>
                    <option value="completed" <%= viewFilters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                    <option value="cancelled" <%= viewFilters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                <input type="date" name="from" value="<%= viewFilters.from || '' %>" class="border rounded p-2"/>
                <input type="date" name="to"   value="<%= viewFilters.to   || '' %>" class="border rounded p-2"/>
                <button type="submit" class="bg-primary text-white px-4 py-2 rounded hover:opacity-90">Filter</button>
            </form>

            <!-- Orders Table -->
            <div class="overflow-x-auto bg-white p-4 rounded-xl shadow border">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-100">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">No</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Order ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Customer</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Total</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Payment</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Action</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        <% orders.forEach((order, index) => { %>
                        <%
                            const rawDate = new Date(order.date);
                            const formattedDate = rawDate.toLocaleDateString('en-GB', {
                                day: '2-digit', month: 'short', year: 'numeric'
                            }) + ' ' + rawDate.toLocaleTimeString('en-US', {
                                hour: '2-digit', minute: '2-digit', hour12: true
                            });
                        %>
                        <tr class="hover:bg-slate-50">
                            <!-- Serial No -->
                            <td class="px-6 py-4 whitespace-nowrap text-slate-500 text-sm"><%= index + 1 %></td>
                            <!-- Order ID: shows order_number from DB (e.g. NTE-20260885), fallback to id -->
                            <td class="px-6 py-4 whitespace-nowrap font-semibold text-primary"><%= order.order_number || order.id %></td>
                            <td class="px-6 py-4 whitespace-nowrap"><%= order.customerName || '—' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600"><%= formattedDate %></td>
                            <td class="px-6 py-4 whitespace-nowrap font-semibold">LKR <%= Number(order.total).toLocaleString() %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm capitalize"><%= order.paymentMethod || order.payment_method || 'cod' %></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if(order.status === 'completed'){ %>
                                    <span class="status-completed">Completed</span>
                                <% } else if(order.status === 'pending'){ %>
                                    <span class="status-pending">Pending</span>
                                <% } else { %>
                                    <span class="status-cancelled">Cancelled</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap space-x-2">
                                <a href="/admin/orders/view/<%= order.id %>"   class="text-blue-600 hover:underline">View</a>
                                <span class="text-slate-300">|</span>
                                <a href="/admin/orders/edit/<%= order.id %>"   class="text-yellow-600 hover:underline">Edit</a>
                                <span class="text-slate-300">|</span>
                                <a href="/admin/orders/delete/<%= order.id %>" class="text-red-600 hover:underline"
                                   onclick="return confirm('Delete this order?')">Delete</a>
                            </td>
                        </tr>
                        <% }) %>

                        <% if(orders.length === 0){ %>
                        <tr>
                            <td colspan="8" class="px-6 py-8 text-center text-slate-400">No orders found.</td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>

        <!-- Footer -->
        <%- include('../partials/footer') %>

    </main>
</div>

</body>
</html>
